# Tracera API credentials template — copy to .env and fill in.
# Free signup links are in README.md and 00_data_sources_index.ipynb.

NASS_API_KEY=             # https://quickstats.nass.usda.gov/api
NOAA_CDO_TOKEN=           # https://www.ncdc.noaa.gov/cdo-web/token
FRED_API_KEY=             # https://fredaccount.stlouisfed.org/apikeys
ERS_API_KEY=              # https://api.data.gov/signup
OPENET_API_KEY=           # https://etdata.org  (account -> request key)
AMS_API_KEY=              # https://mymarketnews.ams.usda.gov  (optional)
PC_SDK_SUBSCRIPTION_KEY=  # https://planetarycomputer.microsoft.com  (optional)
